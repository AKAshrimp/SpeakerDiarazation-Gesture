<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="● 連線中"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvGestureSpeakingChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_status_chip"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="手勢播報中"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingBottom="16dp"
                android:text="語者辨識"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/ic_settings"
                android:tint="#FFFFFF"
                android:contentDescription="設定"
                android:focusable="true"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLanguageLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="語言"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner_background"
            android:padding="8dp"
            android:popupBackground="@drawable/bg_spinner_popup"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="開始錄音"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <CheckBox
            android:id="@+id/cbEnableGesture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="啟用手勢（相機）"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnTestGesture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="僅測試手勢"
            android:textSize="16sp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:padding="14dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTranscriptLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="轉寫："
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#2E2E2E"
        android:clipToPadding="false"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="140dp">

        <TextView
            android:id="@+id/tvTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:lineSpacingExtra="4dp"/>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutRecordingControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/btnPauseRecording"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:paddingLeft="28dp"
            android:paddingRight="28dp"
            android:text="暫停錄音"
            android:textSize="18sp"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btnStopRecording"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:text="停止錄音"
            android:textSize="18sp"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvGestureStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:layout_marginBottom="140dp"
        android:background="#AA000000"
        android:padding="10dp"
        android:text="手勢：--"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
